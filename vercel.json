{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "python3 build.py || true",
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": false,
  "trailingSlash": true,
  "crons": [
    {
      "path": "/api/cron-sync",
      "schedule": "30 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/logo.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/episodes.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300" }]
    },
    {
      "source": "/content/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=300" }]
    }
  ]
}
